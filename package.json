  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/express": "^4.17.17",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.6.2",
    "wait-on": "^9.0.10",
    "vite": "6.3.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.steamfree.desktop",
    "productName": "SteamFree",
    "files": [
      "dist/**",
      "dist/electron/**",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "aqgaminghub.exe",
      "icon": "public/icon.ico"
    }
  }
}
