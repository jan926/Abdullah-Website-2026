# Frontend only — never put SERVICE ROLE key here (it would be exposed in the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional — better AI auto-fill (developer, description, tags). Free key: https://rawg.io/apidocs
# VITE_RAWG_API_KEY=your_rawg_api_key_here

# Gemini / AI provider (optional)
# Example: set VITE_GEMINI_API_KEY and VITE_GEMINI_API_URL to enable Gemini Free proxy
# VITE_GEMINI_API_KEY=your_gemini_key_here
# VITE_GEMINI_API_URL=https://your-gemini-endpoint.example/v1/generate

# Server-side proxy variables (recommended)
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_API_URL=https://your-gemini-endpoint.example/v1/generate
# Or use a Google service account (base64 encoded JSON):
# GOOGLE_SERVICE_ACCOUNT_BASE64=base64-of-service-account-json
# GEMINI_MODEL=models/gemini-1.0
