# ============================================================================
# AQ Gaming Hub - Environment Variables
# ============================================================================

# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Application Configuration (OPTIONAL)
VITE_API_URL=http://localhost:5173
VITE_APP_NAME=AQ Gaming Hub
VITE_APP_VERSION=1.0.0

# Admin Configuration (DEVELOPMENT ONLY)
# Remove in production - use secure environment variables instead
VITE_ADMIN_SECRET=your_admin_secret_here_dev_only

# Feature Flags
VITE_ENABLE_2FA=false
VITE_REQUIRE_EMAIL_VERIFICATION=true
VITE_MAINTENANCE_MODE=false

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env to Git - use .env.local for local overrides
# 2. NEVER put SERVICE ROLE key here - it would be exposed in browser
# 3. Only include ANON_KEY (public, read-only)
# 4. For production, use Vercel Environment Variables or similar secure storage
# 5. Rotate secrets regularly
# 6. Keep different secrets for dev, staging, and production
# ============================================================================
